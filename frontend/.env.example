# Vite frontend config
# Vite supports .env, .env.local, .env.development, .env.production.
# For local private config, use frontend/.env.local:
#   cp frontend/.env.local.example frontend/.env.local
# Only variables prefixed with VITE_ are exposed to browser code.

# Nest.js API base URL
VITE_API_BASE_URL=http://localhost:4000/api

# Deployed SignatureAirdrop contract address.
# Replace after deployment.
VITE_AIRDROP_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# WalletConnect project id for RainbowKit.
# Get one at https://cloud.walletconnect.com/
# This is not a private key, but can still be environment-specific.
VITE_WALLETCONNECT_PROJECT_ID=
