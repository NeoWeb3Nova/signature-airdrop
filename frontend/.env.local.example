# Local Vite frontend config
# Copy this file to frontend/.env.local and edit values:
#   cp frontend/.env.local.example frontend/.env.local
# .env.local is ignored by git and is the recommended place for local/private Vite settings.

VITE_API_BASE_URL=http://localhost:4000/api
VITE_AIRDROP_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_WALLETCONNECT_PROJECT_ID=
